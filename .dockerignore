# Keep the build context lean and secrets out of the image.
#
# NOTE: `outputs/` is intentionally excluded — a fresh container regenerates it
# from the tracked demo packages via scripts/seed_demo_runs.py, so we never ship
# a developer's local runs/DB. `ui/public/demo/` is NOT ignored (only
# ui/node_modules and ui/dist are), so the Dockerfile can COPY the demo packages.

# Secrets — keys arrive as runtime env vars, never baked into the image.
.env
.env.*

# Python virtualenv / caches (the image builds its own via uv).
.venv
__pycache__
**/__pycache__
*.pyc
.pytest_cache
.mypy_cache
.ruff_cache

# Node / frontend build artifacts (the UI is hosted separately on Vercel).
node_modules
ui/node_modules
ui/dist

# Local run outputs + database — regenerated by the seed script from the demo.
outputs

# Eval report artifacts (large, not needed at runtime).
evals/reports

# VCS + tooling metadata.
.git
.gitignore
.vercel
.DS_Store

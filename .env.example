# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in. .env is gitignored — never commit real keys.
# FIXTURE mode needs NO keys at all (deterministic synthetic run):
#   uv run competitive-agent demo-check --mode fixture
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED for a live run ──────────────────────────────────────────────────
# Anthropic — classification (Haiku), judgment/opportunities/chat (reasoning tier).
ANTHROPIC_API_KEY=
# Exa — retrieval only (neural search, domain-scoped discovery, date-windowed
# prior sampling, per-post LinkedIn extraction, the Similarweb traffic partner).
EXA_API_KEY=

# ── OPTIONAL providers (each degrades to a typed honest skip when absent) ─────
# SerpApi — REAL Google ad creatives via the Ads Transparency Center API
# (advertiser-verified, formats, run dates, video-ad copy). Free tier ~100/mo.
# Without it, ad collection falls back to Exa web discovery then a typed skip.
# https://serpapi.com
SERPAPI_API_KEY=
# Gemini (Google AI Studio, free) — LIVE SERP intelligence for paid-search
# targeting (People-Also-Ask questions, related searches) via Search grounding.
# The grounding tool needs BILLING enabled on the key's project; without it the
# paid-search section is honest-empty. Volumes/CPC are never returned by this
# provider (validate free in Google Keyword Planner).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Meta Ad Library Graph API — real Meta creatives + EU impression buckets.
# Needs a Facebook developer account/token. Absent -> typed skip.
META_ADS_ACCESS_TOKEN=
# Unused by default; SEMrush is an alternative keyword VOLUME provider seam
# (superseded by the Gemini SERP path above).
PERPLEXITY_API_KEY=
SEMRUSH_API_KEY=
# NOTE: a Google Ads API *developer token* CANNOT read competitors' ad creatives
# (it manages your own account; there is no Google API for the Transparency
# Center). Use SERPAPI_API_KEY for real Google creatives.
GOOGLE_ADS_DEVELOPER_TOKEN=

# ── Run defaults ─────────────────────────────────────────────────────────────
PLAYWRIGHT_ENABLED=false
DEFAULT_RUN_MODE=cached
DEFAULT_RESEARCH_BUDGET_USD=5.00
DEFAULT_MAX_RUNTIME_SECONDS=600
DEFAULT_LOOKBACK_DAYS=365
MAX_PARALLEL_FETCHES=5
MAX_PARALLEL_EXTRACTIONS=4
PER_DOMAIN_CONCURRENCY=2
LOG_LEVEL=INFO
